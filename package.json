{
  "name": "medusa-plugin-pennylane",
  "version": "0.0.1",
  "description": "Sync Medusa v2 orders into Pennylane as customer invoices with automatic Stripe reconciliation.",
  "author": "Pierre Bertet",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pierre-b/medusa-pennylane.git"
  },
  "bugs": {
    "url": "https://github.com/pierre-b/medusa-pennylane/issues"
  },
  "homepage": "https://github.com/pierre-b/medusa-pennylane#readme",
  "keywords": [
    "medusa",
    "medusa-plugin",
    "medusa-v2",
    "medusa-plugin-integration",
    "pennylane",
    "invoicing",
    "accounting",
    "france",
    "stripe"
  ],
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit --passWithNoTests",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit --passWithNoTests",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit --passWithNoTests"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/icons": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "@medusajs/test-utils": "2.13.6",
    "@medusajs/ui": "4.1.6",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.2",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/icons": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "@medusajs/test-utils": "2.13.6",
    "@medusajs/ui": "4.1.6"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.12.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
